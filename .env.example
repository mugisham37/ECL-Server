# Application
APP_ENV=development
APP_NAME="ECL Platform API"
APP_VERSION=1.0.0
DEBUG=true
SECRET_KEY=change-me-use-secrets-token-hex-32

# Server
HOST=0.0.0.0
PORT=8000
WORKERS=4
RELOAD=false

# Database
DATABASE_URL=postgresql+asyncpg://ecl:ecl_password@localhost:5434/ecl_db
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_POOL_TIMEOUT=30

# Redis
REDIS_URL=redis://localhost:6380/0
REDIS_CELERY_URL=redis://localhost:6380/1
REDIS_CACHE_TTL_DEFAULT=300

# JWT (run: make generate-keys)
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=
JWT_KEY_ID=ecl-auth-2026-01
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
JWT_ALGORITHM=RS256

# Argon2
ARGON2_MEMORY_COST=65536
ARGON2_TIME_COST=3
ARGON2_PARALLELISM=4

# CORS
CORS_ORIGINS=http://localhost:3000

# Email
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USERNAME=apikey
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@eclplatform.com
SMTP_FROM_NAME="ECL Platform"
SMTP_TLS=true

# Frontend
FRONTEND_URL=http://localhost:3000

# HIBP
HIBP_TIMEOUT_SECONDS=2
HIBP_ENABLED=true

# Observability
SENTRY_DSN=
LOG_LEVEL=INFO
LOG_FORMAT=console
RELEASE=dev

# Rate limiting
RATE_LIMIT_ENABLED=true

# Lockout
LOCKOUT_THRESHOLD_1=5
LOCKOUT_THRESHOLD_2=10
LOCKOUT_THRESHOLD_3=20

# Metrics
METRICS_TOKEN=

# Test
CELERY_TASK_ALWAYS_EAGER=false
SUPPRESS_EMAIL_SEND=false

# Proxy (set true behind nginx/load balancer)
TRUST_PROXY_HEADERS=false
TRUSTED_PROXY_COUNT=1

# CSRF (generate: python -c "import secrets; print(secrets.token_hex(32))")
CSRF_SECRET=

# TOTP 2FA (generate: python scripts/generate_keys.py --totp)
TOTP_ISSUER_NAME="ECL Platform"
TOTP_ENCRYPTION_KEY=

# Security salts (generate: python -c "import secrets; print(secrets.token_hex(32))")
IP_HASH_SALT=
