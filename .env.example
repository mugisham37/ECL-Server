# App
APP_ENV=development          # development | staging | production
APP_NAME=ECL Platform API
APP_VERSION=1.0.0
DEBUG=false
SECRET_KEY=                  # required, 32+ chars. Generate: openssl rand -hex 32

# Server
HOST=0.0.0.0
PORT=8000
WORKERS=4
RELOAD=false

# Database (required)
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/dbname
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_POOL_TIMEOUT=30

# Redis (required in production — no localhost in prod)
REDIS_URL=redis://localhost:6379/0
REDIS_CELERY_URL=redis://localhost:6379/1
REDIS_CACHE_TTL_DEFAULT=300

# JWT (RS256, base64-encoded PEM keys). Generate with scripts/generate_keys.py
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=
JWT_KEY_ID=ecl-auth-2026-01
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
JWT_ALGORITHM=RS256

# Password hashing (Argon2)
ARGON2_MEMORY_COST=65536
ARGON2_TIME_COST=3
ARGON2_PARALLELISM=4

# CORS — comma-separated list of allowed origins; must NOT be localhost in production
CORS_ORIGINS=http://localhost:3000

# SMTP / Email
SMTP_HOST=localhost
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@eclplatform.com
SMTP_FROM_NAME=ECL Platform
SMTP_TLS=true

# Frontend URL — must NOT be localhost in production
FRONTEND_URL=http://localhost:3000

# HaveIBeenPwned password check
HIBP_TIMEOUT_SECONDS=2.0
HIBP_ENABLED=true

# Observability
SENTRY_DSN=
LOG_LEVEL=INFO
LOG_FORMAT=console           # json | console
RELEASE=dev

# Rate limiting / lockout
RATE_LIMIT_ENABLED=true
LOCKOUT_THRESHOLD_1=5
LOCKOUT_THRESHOLD_2=10
LOCKOUT_THRESHOLD_3=20

# Metrics endpoint auth token
METRICS_TOKEN=

# Celery — keep false except in tests
CELERY_TASK_ALWAYS_EAGER=false

REFRESH_COOKIE_NAME=ecl_refresh

# Set true only in test/dev to suppress real email sends
SUPPRESS_EMAIL_SEND=false

# Set true when running behind a reverse proxy / load balancer
TRUST_PROXY_HEADERS=false
TRUSTED_PROXY_COUNT=1

# Security secrets — required (no insecure default) in production
CSRF_SECRET=                 # 32+ chars
IP_HASH_SALT=                # random string, not the literal default

TOTP_ISSUER_NAME=ECL Platform
TOTP_ENCRYPTION_KEY=

# Object storage (S3/MinIO) — required (no dev default) in production
STORAGE_ENDPOINT_URL=http://localhost:9000
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_BUCKET_NAME=ecl-platform
STORAGE_REGION=us-east-1
MAX_UPLOAD_BYTES=52428800

# Compute task time limits (seconds)
COMPUTE_SOFT_TIME_LIMIT=1800
COMPUTE_HARD_TIME_LIMIT=2400

SESSION_IDLE_TIMEOUT_MINUTES=30
